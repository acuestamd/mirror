# Mirror — environment variables (set these in Vercel, or in .env.local for dev)

# X (Twitter) OAuth 2.0 app — create at https://developer.x.com → Projects & Apps.
# Set the app type to "Web App / Confidential client" and enable OAuth 2.0.
# Required scopes: tweet.read users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# The OAuth 2.0 redirect/callback URL. Must EXACTLY match what you register in the
# X app's "Callback URI / Redirect URL" settings.
#   prod:  https://your-deployment.vercel.app/api/callback
#   dev:   http://127.0.0.1:3000/api/callback   (X allows http only on loopback; use 127.0.0.1, not localhost)
X_REDIRECT_URI=http://127.0.0.1:3000/api/callback

# Anthropic API key (server-side only — never exposed to the browser).
ANTHROPIC_API_KEY=

# Optional: model override (defaults to claude-opus-4-8)
# MIRROR_MODEL=claude-opus-4-8
